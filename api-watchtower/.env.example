# ============================================================
# API WATCHTOWER - ENV EXAMPLE
# ============================================================

NODE_ENV=development

# ============================================================
# SERVER
# ============================================================

PORT=3567
HOST=127.0.0.1

# ============================================================
# CORS
# ============================================================

CORS_ORIGIN=http://127.0.0.1:5173

# ============================================================
# STORAGE
# ============================================================

DATA_DIR=apps/server/data
LOG_DIR=apps/server/logs

# ============================================================
# REQUESTS
# ============================================================

REQUEST_TIMEOUT_MS=30000
REQUEST_MAX_BODY_SIZE=1048576

# ============================================================
# DESKTOP
# ============================================================

VITE_API_BASE_URL=http://127.0.0.1:3567/api